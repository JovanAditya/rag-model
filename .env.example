# ==============================================
# RAG MODEL CONFIGURATION
# ==============================================
# Konfigurasi untuk rag-model (core RAG engine)
# Salin file ini ke .env dan sesuaikan nilainya

# ==============================================
# EMBEDDING MODEL
# ==============================================
EMBEDDING_MODEL=indobenchmark/indobert-base-p2
EMBEDDING_DEVICE=cuda
# Opsi device: cuda, cpu, mps (Mac)
EMBEDDING_BATCH_SIZE=32

# ==============================================
# RERANKER MODEL
# ==============================================
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ==============================================
# LLM PROVIDER
# ==============================================
# Opsi: gemini, openai, anthropic, ollama, qwen, llama
LLM_PROVIDER=gemini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI API ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# --- Anthropic API ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- Ollama / Local LLM ---
# Pastikan Ollama running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
# Model lokal yang tersedia:
#   - llama3.2:latest (ringan, cepat)
#   - qwen3:8b (performa bagus untuk bahasa Indonesia)

# --- Alias untuk local LLM ---
QWEN_MODEL=qwen3:8b
LLAMA_MODEL=llama3.2:latest

# ==============================================
# RETRIEVAL PARAMETERS
# ==============================================
PIPELINE_TYPE=advanced
MAX_RESULTS=5
USE_RERANKING=true
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# ==============================================
# BM25 PARAMETERS (Advanced)
# ==============================================
BM25_K1=1.5
BM25_B=0.75
BM25_NGRAM_MIN=1
BM25_NGRAM_MAX=2

# ==============================================
# INDEX PATHS
# ==============================================
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
COLLECTION_NAME=academic_docs
INDEX_CACHE_DIR=./data/cache

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=INFO
